<!--pages/schedule/import.wxml-->
<view class="import-page">
  <view class="card">
    <view class="card-title">📂 选择课表 PDF</view>
    <view class="file-area" bindtap="onChooseFile">
      <block wx:if="{{filePath}}">
        <text class="file-icon">📄</text>
        <text class="file-name">{{fileName}}</text>
        <text class="file-repick">点击更换</text>
      </block>
      <block wx:else>
        <text class="file-placeholder">📁 点击选择 PDF 文件</text>
        <text class="file-hint">从教务系统导出的课表 PDF</text>
      </block>
    </view>
  </view>

  <view class="card" hidden="{{!filePath}}">
    <view class="card-title">🔍 解析课表</view>
    <button class="parse-btn" bindtap="onParsePDF" loading="{{parsing}}" disabled="{{!filePath || parsing}}">开始解析</button>
  </view>

  <view class="card" hidden="{{!parseResult}}">
    <view class="card-title">📋 解析结果</view>
    <view class="result-summary">
      <text>{{semesterLabel || semester || '未知学期'}}</text>
      <text class="course-count">{{courses.length}} 门课程</text>
    </view>
    <scroll-view scroll-y class="course-preview">
      <view class="preview-item {{item._conflict ? 'has-conflict' : ''}}" wx:for="{{courses}}" wx:key="index">
        <view class="preview-left">
          <text class="preview-name">{{item.name}}</text>
          <text class="preview-detail">{{item.teacher}} · {{item.location}} · {{item.startSlot}}-{{item.endSlot}}节</text>
          <text class="conflict-hint" wx:if="{{item._conflict}}">⚠ 与「{{item._conflict}}」时间冲突</text>
        </view>
        <view class="preview-actions">
          <picker range="{{weekdayNames}}" value="{{item.weekday - 1}}" data-index="{{index}}" bindchange="onWeekdayChange">
            <view class="weekday-picker {{item.weekday !== item._originalWeekday ? 'changed' : ''}}">
              周{{item.weekday}}
            </view>
          </picker>
          <view class="skip-toggle {{item._replace ? 'active' : 'skipped'}}" data-index="{{index}}" bindtap="onToggleCourse"
            wx:if="{{item._conflict}}">
            {{item._replace ? '覆盖' : '跳过'}}
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="card" hidden="{{!parseResult || courses.length === 0 || importDone}}">
    <view class="card-title">💾 导入到课表</view>
    <view class="mode-selector">
      <view class="mode-item {{importMode === 'replace' ? 'active' : ''}}" data-mode="replace" bindtap="onModeSelect">
        <text class="mode-title">覆盖导入</text>
        <text class="mode-desc">替换本学期旧课程</text>
      </view>
      <view class="mode-item {{importMode === 'append' ? 'active' : ''}}" data-mode="append" bindtap="onModeSelect">
        <text class="mode-title">追加导入</text>
        <text class="mode-desc">保留旧课程，追加</text>
      </view>
      <view class="mode-item {{importMode === 'merge' ? 'active' : ''}}" data-mode="merge" bindtap="onModeSelect">
        <text class="mode-title">智能合并</text>
        <text class="mode-desc">冲突的覆盖、无冲突追加</text>
      </view>
    </view>
    <button class="import-btn" bindtap="onConfirmImport" loading="{{importing}}">确认导入</button>
  </view>

  <view class="card done-card" hidden="{{!importDone}}">
    <view class="done-icon">✅</view>
    <view class="done-text">成功导入 {{importCount}} 门课程</view>
    <button class="back-btn" bindtap="onBackToSchedule">返回课表</button>
  </view>
</view>
