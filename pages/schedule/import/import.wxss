/* pages/schedule/import.wxss */
.import-page {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 60rpx;
}
.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}
.card-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

/* 格式选择 */
.format-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.format-tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  background: #fafafa;
}
.format-tab.active {
  border-color: #1976D2;
  background: #E3F2FD;
}
.format-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}
.format-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}
.format-ext {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 文件选择区 */
.file-area {
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  padding: 40rpx 20rpx;
  text-align: center;
}
.file-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 8rpx;
}
.file-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  display: block;
}
.file-repick {
  font-size: 22rpx;
  color: #1976D2;
  margin-top: 4rpx;
  display: block;
}
.file-placeholder {
  font-size: 30rpx;
  color: #999;
  display: block;
}
.file-hint {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 8rpx;
  display: block;
}

/* 解析 */
.parse-btns {
  display: flex;
  gap: 16rpx;
}
.parse-btn {
  flex: 1;
  background: #1976D2;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}
.tip {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #e67e22;
  background: #FFF3E0;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
}

/* 结果 */
.result-summary {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}
.course-count {
  color: #1976D2;
  font-weight: 600;
}
.course-preview {
  max-height: 500rpx;
  border: 1rpx solid #f0f0f0;
  border-radius: 8rpx;
}
.preview-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.preview-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
}
.preview-detail {
  font-size: 22rpx;
  color: #999;
}
.preview-time {
  font-size: 24rpx;
  color: #1976D2;
  display: block;
}
.weekday-picker {
  font-size: 26rpx;
  color: #1976D2;
  padding: 6rpx 16rpx;
  border: 1rpx solid #BBDEFB;
  border-radius: 6rpx;
  background: #E3F2FD;
  white-space: nowrap;
}
.weekday-picker.changed {
  border-color: #FF9800;
  background: #FFF3E0;
  color: #E65100;
}

/* 模式选择 */
.mode-selector {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.mode-item {
  flex: 1;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  text-align: center;
}
.mode-item.active {
  border-color: #1976D2;
  background: #E3F2FD;
}
.mode-title {
  font-size: 28rpx;
  font-weight: 600;
  display: block;
}
.mode-desc {
  font-size: 22rpx;
  color: #999;
}
.import-btn {
  background: #1976D2;
  color: #fff;
  border-radius: 40rpx;
}
.done-card {
  text-align: center;
  padding: 60rpx 40rpx;
}
.done-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}
.done-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #4CAF50;
  margin-bottom: 30rpx;
}
.back-btn {
  background: #1976D2;
  color: #fff;
  border-radius: 40rpx;
}
