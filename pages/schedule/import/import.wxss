/* pages/schedule/import.wxss */
.import-page { padding: 20rpx; background: #f5f5f5; min-height: 100vh; padding-bottom: 60rpx; }
.card { background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 20rpx; }
.card-title { font-size: 30rpx; font-weight: 700; margin-bottom: 20rpx; }
.file-area { border: 2rpx dashed #ccc; border-radius: 12rpx; padding: 40rpx 20rpx; text-align: center; }
.file-icon { font-size: 48rpx; display: block; margin-bottom: 8rpx; }
.file-name { font-size: 28rpx; color: #333; font-weight: 600; display: block; }
.file-repick { font-size: 22rpx; color: #1976D2; margin-top: 4rpx; display: block; }
.file-placeholder { font-size: 30rpx; color: #999; display: block; }
.file-hint { font-size: 22rpx; color: #bbb; margin-top: 8rpx; display: block; }
.parse-btn { background: #1976D2; color: #fff; border-radius: 40rpx; font-size: 28rpx; }
.result-summary { display: flex; justify-content: space-between; font-size: 26rpx; color: #666; margin-bottom: 16rpx; }
.course-count { color: #1976D2; font-weight: 600; }
.course-preview { max-height: 500rpx; border: 1rpx solid #f0f0f0; border-radius: 8rpx; }
.preview-item { display: flex; justify-content: space-between; align-items: center; padding: 16rpx; border-bottom: 1rpx solid #f5f5f5; }
.preview-left { flex: 1; }
.preview-name { font-size: 28rpx; font-weight: 600; color: #333; display: block; }
.preview-detail { font-size: 22rpx; color: #999; }
.weekday-picker { font-size: 26rpx; color: #1976D2; padding: 6rpx 16rpx; border: 1rpx solid #BBDEFB; border-radius: 6rpx; background: #E3F2FD; white-space: nowrap; }
.weekday-picker.changed { border-color: #FF9800; background: #FFF3E0; color: #E65100; }
.mode-selector { display: flex; gap: 16rpx; margin-bottom: 20rpx; }
.mode-item { flex: 1; padding: 20rpx; border: 2rpx solid #e0e0e0; border-radius: 10rpx; text-align: center; }
.mode-item.active { border-color: #1976D2; background: #E3F2FD; }
.mode-title { font-size: 28rpx; font-weight: 600; display: block; }
.mode-desc { font-size: 22rpx; color: #999; }
.import-btn { background: #1976D2; color: #fff; border-radius: 40rpx; }
.done-card { text-align: center; padding: 60rpx 40rpx; }
.done-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.done-text { font-size: 32rpx; font-weight: 600; color: #4CAF50; margin-bottom: 30rpx; }
.back-btn { background: #1976D2; color: #fff; border-radius: 40rpx; }
.has-conflict { background: #FFF8E1; }
.conflict-hint { font-size: 20rpx; color: #E65100; margin-top: 4rpx; display: block; }
.preview-actions { display: flex; align-items: center; gap: 10rpx; }
.skip-toggle { font-size: 22rpx; padding: 6rpx 12rpx; border-radius: 6rpx; white-space: nowrap; }
.skip-toggle.active { background: #E8F5E9; color: #2E7D32; border: 1rpx solid #A5D6A7; }
.skip-toggle.skipped { background: #FFF3E0; color: #E65100; border: 1rpx solid #FFCC80; }
