/* pages/schedule/schedule.wxss */
.schedule-page {
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 20rpx;
}

/* 头部 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}
.semester-picker {
  display: flex;
  align-items: center;
}
.semester-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}
.arrow {
  font-size: 20rpx;
  color: #999;
  margin-left: 8rpx;
}
.toolbar {
  display: flex;
  gap: 20rpx;
}
.tool-btn {
  font-size: 26rpx;
  color: #1976D2;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  background: #E3F2FD;
}

/* 周次切换 */
.week-switcher {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  margin: 12rpx 0;
}
.week-btn {
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  border-radius: 50%;
  background: #E3F2FD;
  color: #1976D2;
  font-size: 28rpx;
  font-weight: bold;
}
.week-btn.disabled {
  background: #f0f0f0;
  color: #ccc;
}
.week-info {
  margin: 0 40rpx;
  text-align: center;
}
.week-num {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}
.week-hint {
  font-size: 22rpx;
  color: #999;
  display: block;
}
.week-date-hint {
  font-size: 20rpx;
  color: #bbb;
  display: block;
  margin-top: 4rpx;
}

/* 课表网格 */
.schedule-grid {
  margin: 0 12rpx;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}
.grid-header {
  display: flex;
  border-bottom: 1rpx solid #eee;
  background: #fafafa;
}
.corner-cell {
  width: 90rpx;
  padding: 12rpx 4rpx;
  text-align: center;
  font-size: 22rpx;
  color: #999;
  flex-shrink: 0;
}
.weekday-cell {
  flex: 1;
  text-align: center;
  padding: 16rpx 4rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #555;
}
.grid-body {
  height: auto;
  min-height: 600rpx;
}
.grid-row {
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
  min-height: 52rpx;
}
.period-cell {
  width: 90rpx;
  padding: 8rpx 4rpx;
  text-align: center;
  background: #fafafa;
  border-right: 1rpx solid #f0f0f0;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.period-num {
  font-size: 22rpx;
  color: #666;
  font-weight: 600;
}
.period-time {
  font-size: 18rpx;
  color: #bbb;
}
.course-cell {
  flex: 1;
  min-height: 52rpx;
  position: relative;
  border-right: 1rpx solid #f9f9f9;
}

/* 课程卡片 */
.course-card {
  position: absolute;
  left: 2rpx;
  right: 2rpx;
  top: 1rpx;
  z-index: 2;
  padding: 6rpx 8rpx;
  border-radius: 6rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}
.course-name {
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.2;
}
.course-location,
.course-teacher,
.course-weeks {
  font-size: 18rpx;
  opacity: 0.85;
  line-height: 1.3;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

/* 空状态 */
.empty-state {
  padding: 120rpx 40rpx;
  text-align: center;
}
.empty-icon {
  font-size: 80rpx;
}
.empty-text {
  font-size: 30rpx;
  color: #999;
  margin: 20rpx 0 40rpx;
}
.empty-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  align-items: center;
}
.action-btn {
  width: 400rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  background: #f0f0f0;
  color: #333;
}
.action-btn.primary {
  background: #1976D2;
  color: #fff;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 100rpx;
  color: #999;
}
