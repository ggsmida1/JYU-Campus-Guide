/* pages/schedule/reminder-settings.wxss */
.settings-page {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 60rpx;
}
.section {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}
.setting-item.half {
  flex: 1;
  flex-direction: column;
  align-items: flex-start;
}
.setting-row {
  display: flex;
  gap: 20rpx;
}
.item-left {
  flex: 1;
}
.item-label {
  font-size: 28rpx;
  color: #333;
  display: block;
}
.item-desc {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 4rpx;
  display: block;
}
.picker-value {
  font-size: 28rpx;
  color: #1976D2;
}
.time-input,
.date-input {
  width: 180rpx;
  height: 64rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 12rpx;
  font-size: 28rpx;
  margin-top: 8rpx;
}
.num-input {
  width: 100rpx;
  height: 64rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 12rpx;
  font-size: 28rpx;
  text-align: center;
}
.hint {
  font-size: 22rpx;
  color: #ccc;
  margin-top: 12rpx;
  text-align: center;
}
.subscribe-btn {
  background: #4CAF50;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  margin-top: 10rpx;
}
