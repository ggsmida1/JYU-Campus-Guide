<!--pages/more/statement/statement.wxml-->
<view class="card">
  <view class="card-title">
    <image class="card-title-img" src="{{statement}}" />
    <view class="card-title-font"> 软件声明 </view>
  </view>

  <view class="card-container">
    <view class="card-container-title">
      <image class="card-container-title-img" src="{{message}}" />
      <view class="card-container-title-font"> 声明 </view>
    </view>
    <view class="card-container-text">
      <!-- {{miniprogram_name}}小程序 | {{information.type}} -->
      {{information.type}}：{{miniprogram_name}}小程序
    </view>

    <view class="card-container-text">
      <!-- {{information.author}} | 指导老师:{{information.teacher}} -->
      作者：{{information.author}}
    </view>

    <view class="card-container-text">
      <!-- {{information.author}} | 指导老师:{{information.teacher}} -->
      指导老师：{{information.teacher}}
    </view>

    <view class="card-container-text">
      <!-- 版权归{{school_name_full}}开发者所有! -->
      版权归开发者所有！
    </view>
  </view>

  <view class="card-container">
    <view class="card-container-title">
      <image class="card-container-title-img" src="{{zhixie}}" />
      <view class="card-container-title-font"> 技术说明 </view>
    </view>
    <view class="card-container-all">
      <text class="card-container-text" decode="true">&emsp;&emsp;本小程序基于以下技术栈开发：</text>

      <view class="tech-list">
        <view class="tech-item">微信小程序框架</view>
        <view class="tech-item">微信云开发（云数据库、云函数、云存储）</view>
        <view class="tech-item">腾讯地图 SDK</view>
        <view class="tech-item">和风天气 API</view>
        <view class="tech-item">WeUI 组件库</view>
      </view>
    </view>
  </view>

  <view class="bottom-font"> 智慧导航 · 便捷校园 </view>
</view>
